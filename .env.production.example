POSTGRES_DB=chipping
POSTGRES_USER=chipping
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Bind app to localhost for a Cloudflare Tunnel on the same host.
APP_PORT=127.0.0.1:8000

# Keep Postgres local-only unless you intentionally expose it.
POSTGRES_PORT=127.0.0.1:5432

CORS_ORIGINS=https://chip.cashbaggins.dev
OWNER_PIN=replace-with-owner-pin
OWNER_PASSWORD=
JWT_SECRET=replace-with-a-long-random-secret
SESSION_DAYS=30
COOKIE_SECURE=true
